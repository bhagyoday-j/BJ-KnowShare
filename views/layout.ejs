<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <!-- The above 3 meta tags *must* come first in the head; any other head content must come *after* these tags -->
    <title>
      <% if(settings.website_title && settings.website_title.trim() !== '') { %>
        <%= settings.website_title %>
      <% } else { %>
        News
      <% } %>
    </title>
    <!-- Bootstrap -->
    <link href="/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome Icon -->
    <link rel="stylesheet" href="/css/font-awesome.css">
    <!-- Custom stlylesheet -->
    <link rel="stylesheet" href="/css/style.css">
    <!-- Navbar css -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
<!-- HEADER -->
<div id="header">
    <!-- container -->
    <div class="container">
        <div class="row justify-content-center">
            <!-- LOGO -->
            <div class="col-md-3">
              <% if(settings.website_logo && settings.website_logo.trim() !== '') { %>
                <a href="/" id="logo"><img src="<%= settings.website_logo %>" alt="Logo"/></a>
              <% } else { %>
                <a href="/" id="logo"><img src="/images/news.jpg" alt="Logo" /></a>
              <% } %>
            </div>
            <!-- /LOGO --> 
        </div>
    </div>
</div>
<!-- /HEADER -->
<!-- Menu Bar -->
<nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top shadow-sm">
    <div class="container">
        <a class="navbar-brand d-lg-none" href="#">Menu</a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <li class="nav-item">
                    <a class="nav-link <%= currentPath === '/' ? 'active' : '' %>" href="/">Home</a>
                </li>
                
                <% categories.forEach(function(category) { %>
                  <% let categoryUrl = '/category/' + category.slug; %>
                    <li class="nav-item">
                        <a class="nav-link <%= currentPath === categoryUrl ? 'active' : '' %>" href="/category/<%- category.slug %>">
                            <%= category.name %>
                        </a>
                    </li>
                <% }); %>
            </ul>
            <form class="d-flex" action="/search" method="GET">
                <input class="form-control form-control-sm me-2" type="search" name="search" placeholder="Search...">
                <button class="btn btn-outline-light btn-sm" type="submit"><i class="fa fa-search text-white"></i></button>
            </form>
        </div>
    </div>
</nav>
<!-- /Menu Bar -->

  <div id="main-content">
    <div class="container">
      <div class="row">
        <div class="col-md-8">
          <%- body %>
        </div>
        <!-- sidebar -->
        <%- include('partials/sidebar') %> 
        <!-- /sidebar -->
      </div>
    </div>
  </div>
  <div id ="footer">
      <div class="container">
          <div class="row">
              <div class="col-md-12">
                <% if(settings.footer_description && settings.footer_description.trim() !== '') { %>
                  <span><%= settings.footer_description %></span>
                <% } else { %>
                  <span>Made with ❤️ | © Copyright 2026</span>
                <% } %>
                  
              </div>
          </div>
      </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
